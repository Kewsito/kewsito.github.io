---
// Contact.astro
interface props {
  nombre: string;
  tecnologiasUsadas: string[];
  descripcion: string;
  imagen: string;
}

const {
  educacion = [
    [
      "Universidad Nacional de San Juan",
      "Lic. en Ciencias de la Computacion en Programacion",
      "2021-En curso",
    ],
    [
      "Universidad Nacional de San Juan",
      "Tecnico Universitario en Programacion",
      "2026-Finalizado",
    ],
    ["San Juan TEC", "Introduccion al Desarrollo en Python", "2023-Finalizado"],
    ["San Juan TEC", "Introduccion al Desarrollo en Dart", "2023-Finalizado"],
    ["San Juan TEC", "Base de datos", "2023-Finalizado"],
    [
      "San Juan TEC",
      "Curso de Introduccion al Desarrollo Web",
      "2023-Finalizado",
    ],
  ],
} = Astro.props;

              
---

<section id="contacto" class="py-16" style="background-color: var(--bg-color);">
  <div class="container mx-auto px-4">
    <h2 class="section-title gradient-text">Educacion</h2>
    <p class="mb-10 text-lg" style="color: var(--text-muted);">
      Con esto me entretuve todos estos años
    </p>

    <div
      class="max-w-6xl mx-auto"
      style="box-shadow: 0 4px 6px var(--shadow-color);"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          educacion.map(([institucion, curso, periodo]) => (
            <div class="group relative h-72 overflow-hidden rounded-2xl bg-gradient-to-br from-[#2a2a2a] to-[#1a1a1a] shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105 cursor-pointer border border-gray-700 hover:border-blue-500/50">
              {/* Fondo gradiente animado */}
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 bg-gradient-to-br from-blue-600/10 to-purple-600/10 transition-opacity duration-300" />

              {/* Contenido */}
              <div class="relative h-full flex flex-col justify-between p-6 z-10">
                {/* Período */}
                <div class="flex items-center justify-between">
                  <span class="inline-block px-3 py-1 bg-blue-500/20 text-blue-300 text-xs font-semibold rounded-full border border-blue-500/30">
                    {periodo}
                  </span>
                  <div class="w-2 h-2 rounded-full bg-green-400 group-hover:animate-pulse" />
                </div>

                {/* Centro - Información principal */}
                <div class="flex-1 flex flex-col justify-center space-y-3">
                  <div>
                    <p class="text-sm text-gray-400 uppercase tracking-wide mb-1">
                      Curso
                    </p>
                    <h3 class="text-lg font-bold text-white leading-tight group-hover:text-blue-300 transition-colors">
                      {curso}
                    </h3>
                  </div>
                  <div class="h-0.5 w-12 bg-gradient-to-r from-blue-500 to-transparent" />
                  <div>
                    <p class="text-sm text-gray-400 uppercase tracking-wide mb-1">
                      Institución
                    </p>
                    <p class="text-sm text-gray-300 font-medium">
                      {institucion}
                    </p>
                  </div>
                </div>

                <div class="flex items-center space-x-2 text-xs" class:list={{ "text-green-400": periodo.includes("Finalizado"), "text-yellow-400": !periodo.includes("Finalizado") }}>
                  <div class="w-1 h-1 rounded-full" class:list={{ "bg-green-400": periodo.includes("Finalizado"), "bg-yellow-400": !periodo.includes("Finalizado") }} />
                  <span>{periodo.includes("Finalizado") ? "Completado" : "En curso"}</span>
                </div>
              </div>

              {/* Efecto de luz en hover */}
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 pointer-events-none">
                <div class="absolute w-40 h-40 bg-blue-400/30 blur-3xl -top-20 -right-20 group-hover:animate-pulse" />
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mx-auto flex items-center space-x-3"></div>
  </div>
</section>
